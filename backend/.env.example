# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/aimers

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Provider (pick one)
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Demo login (seeded)
DEMO_EMAIL=demo@aimers.com
DEMO_PASSWORD=Demo@1234
