# Server
PORT=5000
NODE_ENV=development
# Production: set to your Vercel URL (no trailing slash), e.g. https://aimers.vercel.app
CLIENT_URL=http://localhost:3000

# MongoDB
# Local: mongodb://127.0.0.1:27017/aimers
# Production: MongoDB Atlas SRV URI (required)
MONGODB_URI=mongodb://127.0.0.1:27017/aimers

# JWT — use a long random secret (required in production, 16+ chars)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Provider (pick one)
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Demo login (seeded) — /api/auth/demo is disabled when NODE_ENV=production
DEMO_EMAIL=demo@aimers.com
DEMO_PASSWORD=Demo@1234
